# Configuration du serveur
PORT=5000
NODE_ENV=development

# Configuration de la base de données
DATABASE_URL=sqlite:./data/orders.db

# Configuration Gmail pour l'envoi d'emails
# IMPORTANT: Utilisez un "App Password" au lieu d'un mot de passe normal
# Instructions pour Gmail:
# 1. Allez à https://myaccount.google.com/security
# 2. Activez la "Vérification en deux étapes"
# 3. Allez à https://myaccount.google.com/apppasswords
# 4. Sélectionnez "Mail" et "Windows Computer"
# 5. Copiez le mot de passe généré et mettez-le ci-dessous

GMAIL_EMAIL=your-email@gmail.com
GMAIL_PASSWORD=your-app-password-here

# Configuration frontend
FRONTEND_URL=http://localhost:5173
